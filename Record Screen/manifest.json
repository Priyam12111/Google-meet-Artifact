{
  "manifest_version": 3,
  "name": "Meet Recorder",
  "version": "1.1",
  "description": "A Chrome extension to Record the meeting - By Priyam",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
